---
import Layout from "./Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CategoryBadge from "../components/CategoryBadge.astro";

import ScrollProgress from "../components/fx/ScrollProgress";
import BlurFade from "../components/fx/BlurFade";
import MagneticButton from "../components/fx/MagneticButton";
import TracingBeam from "../components/fx/TracingBeam";
import TableOfContents from "../components/fx/TableOfContents";
import BackToTop from "../components/fx/BackToTop";
import EvervaultCard from "../components/fx/EvervaultCard";

// NEW — Wave 4 post additions
import TLDRPanel from "../components/editorial/post/TLDRPanel";
import ShareMenu from "../components/editorial/post/ShareMenu";
import AuthorBio from "../components/editorial/post/AuthorBio";
import RelatedPosts from "../components/editorial/post/RelatedPosts";

// Wave 5 — Three.js editorial chain
import NextPostBridge from "../components/fx/three/NextPostBridge";

import { getCollection } from "astro:content";

interface NextPostMeta {
  slug: string;
  title: string;
  category: string;
  readingMinutes: number;
}

interface Props {
  title: string;
  description: string;
  category: string;
  kicker?: string;
  pubDate: Date;
  readingMinutes: number;
  slug?: string;
  tldr?: string[];
  nextHook?: string;
  nextPost?: NextPostMeta;
}

const {
  title,
  description,
  category,
  kicker,
  pubDate,
  readingMinutes,
  slug,
  tldr,
  nextHook,
  nextPost,
} = Astro.props;

// Get related posts (all posts except current)
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const currentSlug = slug ?? Astro.url.pathname.split("/").filter(Boolean).pop() ?? "";
const relatedPosts = allPosts
  .filter((p) => p.id !== currentSlug)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 2)
  .map((p) => ({
    id: p.id,
    title: p.data.title,
    description: p.data.description,
    category: p.data.category,
    kicker: p.data.kicker,
    readingMinutes: p.data.readingMinutes,
    pubDate: p.data.pubDate.toISOString(),
  }));

// Subtle category accent
const categoryAccent: Record<string, { border: string; bg: string; tint: string }> = {
  Criterio:   { border: "rgba(227, 6, 19,0.18)",  bg: "rgba(227, 6, 19,0.025)",  tint: "227, 6, 19" },
  Industria:  { border: "rgba(255,107,107,0.14)", bg: "rgba(255,107,107,0.02)", tint: "255, 107, 107" },
  Estrategia: { border: "rgba(125,211,252,0.14)", bg: "rgba(125,211,252,0.02)", tint: "125, 211, 252" },
};
const accent = categoryAccent[category] ?? categoryAccent["Criterio"];
const heroPatternId = `hero-pat-${currentSlug}`;

const dateFormatted = pubDate.toLocaleDateString("es-AR", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const dateISO = pubDate.toISOString();

// Default tldr derived from description if not provided
const tldrItems = tldr ?? [
  description,
];
---

<Layout title={`${title} · Insurreccional`} description={description}>
  <ScrollProgress client:load />
  <BackToTop client:load />

  <Header />

  <main class="relative w-full px-4 pb-32 pt-16 sm:px-6 md:pt-24">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 gap-0 lg:grid-cols-[1fr_minmax(0,680px)_1fr]">

        <!-- Left col (desktop) -->
        <div class="hidden lg:block" aria-hidden="true"></div>

        <!-- Center: article content -->
        <div class="relative">
          <TracingBeam client:visible>
            <!-- Breadcrumb minimal -->
            <BlurFade client:visible delay={0} direction="down">
              <nav class="mb-12 flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.28em] text-mute" aria-label="Breadcrumb">
                <a href="/" class="transition-colors hover:text-bone">Inicio</a>
                <span aria-hidden="true" class="text-mute-dim">/</span>
                <a href="/blog" class="transition-colors hover:text-bone">Archivo</a>
                <span aria-hidden="true" class="text-mute-dim">/</span>
                <span class="text-bone">{category}</span>
              </nav>
            </BlurFade>

            <!-- Hero del post -->
            <header class="mb-14 md:mb-20">
              <BlurFade client:visible delay={0.1}>
                <div class="mb-8 flex flex-wrap items-center justify-between gap-4">
                  <div class="flex flex-wrap items-center gap-4">
                    <CategoryBadge category={category} accent size="md" />
                    <time datetime={dateISO} class="font-mono text-[11px] uppercase tracking-[0.25em] text-mute">
                      {dateFormatted}
                    </time>
                    <span class="font-mono text-[11px] uppercase tracking-[0.25em] text-mute-dim">
                      · {readingMinutes} min
                    </span>
                  </div>
                  <!-- Share menu inline (mobile) / sticky hint desktop -->
                  <ShareMenu client:visible title={title} className="hidden sm:flex" />
                </div>
              </BlurFade>

              <BlurFade client:visible delay={0.2} direction="up">
                {kicker && (
                  <p
                    class="mb-5 border-l-2 pl-3 font-serif text-lg italic text-mute md:text-xl"
                    style={`border-color: ${accent.border}; background: ${accent.bg}; padding-top: 0.25rem; padding-bottom: 0.25rem;`}
                  >
                    · {kicker}
                  </p>
                )}

                <h1 class="font-serif text-4xl font-bold leading-[1.03] tracking-tight text-bone sm:text-5xl md:text-6xl lg:text-[4.5rem]">
                  {title}
                </h1>
              </BlurFade>

              <BlurFade client:visible delay={0.35}>
                <p class="mt-8 max-w-2xl text-lg leading-relaxed text-bone-soft md:text-xl">
                  {description}
                </p>
              </BlurFade>

              <!-- Share menu mobile -->
              <BlurFade client:visible delay={0.4}>
                <div class="mt-6 sm:hidden">
                  <ShareMenu client:visible title={title} />
                </div>
              </BlurFade>
            </header>

            <!-- Hero gráfico generativo -->
            <BlurFade client:visible delay={0.45}>
              <div
                class="relative mb-14 h-56 w-full overflow-hidden rounded-3xl border border-line md:mb-20 md:h-80 lg:h-96"
                style={`background: radial-gradient(circle at 18% 28%, rgba(${accent.tint}, 0.18) 0%, rgba(${accent.tint}, 0.04) 45%, var(--color-surface) 80%);`}
              >
                <svg
                  aria-hidden="true"
                  class="absolute inset-0 h-full w-full"
                  viewBox="0 0 400 240"
                  fill="none"
                  preserveAspectRatio="xMidYMid slice"
                >
                  <defs>
                    <pattern id={heroPatternId} x="0" y="0" width="16" height="16" patternUnits="userSpaceOnUse">
                      <circle cx="2" cy="2" r="0.9" fill={`rgba(${accent.tint}, 0.5)`} />
                    </pattern>
                  </defs>
                  <circle cx="290" cy="80" r="80" fill={`url(#${heroPatternId})`} opacity="0.6" />
                  <path
                    d="M 60 180 Q 130 130, 220 165 T 380 150"
                    stroke={`rgba(${accent.tint}, 0.85)`}
                    stroke-width="1.8"
                    stroke-linecap="round"
                    fill="none"
                  />
                  <circle cx="380" cy="150" r="4" fill={`rgba(${accent.tint}, 1)`} />
                  <g
                    stroke={`rgba(${accent.tint}, 0.45)`}
                    stroke-width="1.2"
                    stroke-linecap="round"
                    fill="none"
                  >
                    <line x1="40" y1="40" x2="100" y2="40" />
                    <line x1="40" y1="60" x2="80" y2="60" />
                    <line x1="40" y1="80" x2="65" y2="80" />
                  </g>
                </svg>

                <div class="absolute left-6 top-6 font-mono text-[10px] uppercase tracking-[0.3em] text-mute md:left-10 md:top-8">
                  / {category}
                </div>
                <div
                  class="absolute bottom-6 right-6 font-serif text-5xl font-bold italic md:bottom-10 md:right-10 md:text-7xl"
                  style={`color: rgba(${accent.tint}, 0.55);`}
                >
                  {readingMinutes}'
                </div>
              </div>
            </BlurFade>

            <!-- TL;DR Panel — before content -->
            <TLDRPanel client:visible items={tldrItems} defaultOpen={false} />

            <!-- Ornamento editorial -->
            <BlurFade client:visible delay={0.45}>
              <div class="mb-14 flex items-center gap-4 md:mb-20">
                <span class="h-[1px] flex-1 bg-line" />
                <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-mute">
                  ·  ·  ·
                </span>
                <span class="h-[1px] flex-1 bg-line" />
              </div>
            </BlurFade>

            <BlurFade client:visible delay={0.5} direction="up">
              <article class="prose-editorial mx-auto">
                <slot />
              </article>
            </BlurFade>

            <!-- Author Bio — after content -->
            <AuthorBio client:visible />

            <!-- Cierre -->
            <BlurFade client:visible delay={0}>
              <footer class="mx-auto mt-24 max-w-2xl border-t border-line pt-10">
                <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-mute">
                  Fin del texto
                </p>
                <EvervaultCard client:visible className="mt-6 border-line">
                  <p class="font-serif text-xl italic text-bone md:text-2xl">
                    Si algo te resonó, compartilo con quien necesitaba leerlo.
                  </p>
                </EvervaultCard>
                <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                  <MagneticButton client:visible href="/blog" className="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.28em] text-bone transition-colors hover:text-neon">
                    <span aria-hidden="true">←</span>
                    Volver al archivo
                  </MagneticButton>
                  <span class="font-mono text-[10px] uppercase tracking-[0.25em] text-mute-dim">
                    Insurreccional · {dateFormatted}
                  </span>
                </div>
              </footer>
            </BlurFade>

            <!-- Chained next post (3D bridge) OR fallback to related posts grid -->
            {nextPost ? (
              <NextPostBridge
                client:visible
                currentTitle={title}
                nextTitle={nextPost.title}
                nextHook={nextHook}
                nextHref={`/blog/${nextPost.slug}`}
                nextCategory={nextPost.category}
                nextReadingMinutes={nextPost.readingMinutes}
              />
            ) : (
              relatedPosts.length > 0 && (
                <RelatedPosts client:visible posts={relatedPosts} />
              )
            )}
          </TracingBeam>
        </div>

        <!-- Right: TableOfContents (sticky, desktop only) -->
        <div class="hidden lg:block">
          <div class="sticky top-24 pl-8 xl:pl-12">
            <TableOfContents client:visible selector="article h2" />
          </div>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</Layout>
