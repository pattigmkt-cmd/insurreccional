---
import Layout from "./Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CategoryBadge from "../components/CategoryBadge.astro";

import ScrollProgress from "../components/fx/ScrollProgress";
import BlurFade from "../components/fx/BlurFade";
import MagneticButton from "../components/fx/MagneticButton";
import TracingBeam from "../components/fx/TracingBeam";
import TableOfContents from "../components/fx/TableOfContents";
import BackToTop from "../components/fx/BackToTop";
import EvervaultCard from "../components/fx/EvervaultCard";

interface Props {
  title: string;
  description: string;
  category: string;
  kicker?: string;
  pubDate: Date;
  readingMinutes: number;
}

const { title, description, category, kicker, pubDate, readingMinutes } = Astro.props;

// Subtle category accent — single element tint, not full palette change
const categoryAccent: Record<string, { border: string; bg: string }> = {
  Criterio:   { border: "rgba(200,255,0,0.18)",  bg: "rgba(200,255,0,0.025)" },
  Industria:  { border: "rgba(255,107,107,0.14)", bg: "rgba(255,107,107,0.02)" },
  Estrategia: { border: "rgba(125,211,252,0.14)", bg: "rgba(125,211,252,0.02)" },
};
const accent = categoryAccent[category] ?? categoryAccent["Criterio"];

const dateFormatted = pubDate.toLocaleDateString("es-AR", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const dateISO = pubDate.toISOString();
---

<Layout title={`${title} · Insurreccional`} description={description}>
  <!-- Scroll progress bar — fija arriba -->
  <ScrollProgress client:load />
  <!-- Back to Top — appears after 30% scroll -->
  <BackToTop client:load />

  <Header />

  <main class="relative w-full px-4 pb-32 pt-16 sm:px-6 md:pt-24">
    <!-- Three-column layout: TracingBeam left | Article center | TOC right -->
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 gap-0 lg:grid-cols-[1fr_minmax(0,680px)_1fr]">

        <!-- Left: TracingBeam (desktop only, hidden via TracingBeam internals) -->
        <div class="hidden lg:block" aria-hidden="true">
          <!-- TracingBeam rail is positioned absolutely inside the center col -->
        </div>

        <!-- Center: article content -->
        <div class="relative">
          <TracingBeam client:visible>
            <!-- Breadcrumb minimal -->
            <BlurFade client:visible delay={0} direction="down">
              <nav class="mb-12 flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.28em] text-mute" aria-label="Breadcrumb">
                <a href="/" class="transition-colors hover:text-bone">Inicio</a>
                <span aria-hidden="true" class="text-mute-dim">/</span>
                <a href="/blog" class="transition-colors hover:text-bone">Archivo</a>
                <span aria-hidden="true" class="text-mute-dim">/</span>
                <span class="text-bone">{category}</span>
              </nav>
            </BlurFade>

            <!-- Hero del post -->
            <header class="mb-14 md:mb-20">
              <BlurFade client:visible delay={0.1}>
                <div class="mb-8 flex flex-wrap items-center gap-4">
                  <CategoryBadge category={category} accent size="md" />
                  <time
                    datetime={dateISO}
                    class="font-mono text-[11px] uppercase tracking-[0.25em] text-mute"
                  >
                    {dateFormatted}
                  </time>
                  <span class="font-mono text-[11px] uppercase tracking-[0.25em] text-mute-dim">
                    · {readingMinutes} min
                  </span>
                </div>
              </BlurFade>

              <BlurFade client:visible delay={0.2} direction="up">
                {kicker && (
                  <p
                    class="mb-5 border-l-2 pl-3 font-serif text-lg italic text-mute md:text-xl"
                    style={`border-color: ${accent.border}; background: ${accent.bg}; padding-top: 0.25rem; padding-bottom: 0.25rem;`}
                  >
                    — {kicker}
                  </p>
                )}

                <h1 class="font-serif text-4xl font-bold leading-[1.03] tracking-tight text-bone sm:text-5xl md:text-6xl lg:text-[4.5rem]">
                  {title}
                </h1>
              </BlurFade>

              <BlurFade client:visible delay={0.35}>
                <p class="mt-8 max-w-2xl text-lg leading-relaxed text-bone-soft md:text-xl">
                  {description}
                </p>
              </BlurFade>
            </header>

            <!-- Ornamento editorial -->
            <BlurFade client:visible delay={0.45}>
              <div class="mb-14 flex items-center gap-4 md:mb-20">
                <span class="h-[1px] flex-1 bg-line" />
                <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-mute">
                  ·  ·  ·
                </span>
                <span class="h-[1px] flex-1 bg-line" />
              </div>
            </BlurFade>

            <BlurFade client:visible delay={0.5} direction="up">
              <article class="prose-editorial mx-auto">
                <slot />
              </article>
            </BlurFade>

            <!-- Cierre -->
            <BlurFade client:visible delay={0}>
              <footer class="mx-auto mt-24 max-w-2xl border-t border-line pt-10">
                <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-mute">
                  Fin del texto
                </p>
                <EvervaultCard client:visible className="mt-6 border-line">
                  <p class="font-serif text-xl italic text-bone md:text-2xl">
                    Si algo te resonó, compartilo con quien necesitaba leerlo.
                  </p>
                </EvervaultCard>
                <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                  <MagneticButton client:visible href="/blog" className="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.28em] text-bone transition-colors hover:text-neon">
                    <span aria-hidden="true">←</span>
                    Volver al archivo
                  </MagneticButton>
                  <span class="font-mono text-[10px] uppercase tracking-[0.25em] text-mute-dim">
                    Insurreccional · {dateFormatted}
                  </span>
                </div>
              </footer>
            </BlurFade>
          </TracingBeam>
        </div>

        <!-- Right: TableOfContents (sticky, desktop only) -->
        <div class="hidden lg:block">
          <div class="sticky top-24 pl-8 xl:pl-12">
            <TableOfContents client:visible selector="article h2" />
          </div>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</Layout>
