---
import CategoryBadge from "./CategoryBadge.astro";

interface Props {
  slug: string;
  title: string;
  description: string;
  kicker?: string;
  category: string;
  pubDate: Date;
  readingMinutes: number;
  variant?: "default" | "feature" | "compact";
  index?: number;
}

const {
  slug,
  title,
  description,
  kicker,
  category,
  pubDate,
  readingMinutes,
  variant = "default",
  index = 0,
} = Astro.props;

const dateFormatted = pubDate.toLocaleDateString("es-AR", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const indexLabel = String(index + 1).padStart(2, "0");

const tintMap: Record<string, string> = {
  Criterio: "227, 6, 19",
  Industria: "255, 107, 107",
  Estrategia: "125, 211, 252",
};
const tint = tintMap[category] ?? tintMap.Criterio;
const patternId = `pat-${variant}-${slug}`;
---

{
  variant === "feature" && (
    <article
      class="group relative overflow-hidden rounded-3xl border border-line bg-surface/60"
      style={`background-image: radial-gradient(circle at 88% 12%, rgba(${tint}, 0.08) 0%, transparent 55%);`}
    >
      <div class="grid gap-0 md:grid-cols-12">
        <div class="flex flex-col justify-between gap-10 p-8 md:col-span-7 md:p-12 lg:p-16">
          <div class="flex items-center gap-3">
            <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-neon">
              [ Destacado ]
            </span>
            <span class="h-px flex-1 bg-line" />
            <span class="font-mono text-[10px] uppercase tracking-[0.25em] text-mute-dim">
              / {indexLabel}
            </span>
          </div>

          <a href={`/blog/${slug}`} class="block">
            <CategoryBadge category={category} accent />
            <p class="mt-5 font-mono text-[10px] uppercase tracking-[0.25em] text-mute">
              {dateFormatted} · {readingMinutes} min
            </p>
            {kicker && (
              <p class="mt-6 font-serif text-base italic text-bone-soft md:text-lg">
                {kicker}
              </p>
            )}
            <h2 class="mt-3 font-serif text-3xl font-bold leading-[1.04] text-bone transition-colors group-hover:text-neon sm:text-4xl md:text-5xl lg:text-[3.5rem]">
              {title}
            </h2>
            <p class="mt-6 max-w-xl text-base leading-relaxed text-mute md:text-lg">
              {description}
            </p>
            <span class="mt-10 inline-flex items-center gap-3 rounded-full bg-neon px-5 py-3 font-mono text-[11px] uppercase tracking-[0.25em] text-ink transition-transform group-hover:translate-x-1">
              Leer artículo completo
              <span aria-hidden="true">→</span>
            </span>
          </a>
        </div>

        <div class="relative min-h-[260px] md:col-span-5 md:min-h-[420px]">
          <svg
            aria-hidden="true"
            class="absolute inset-0 h-full w-full"
            viewBox="0 0 300 400"
            fill="none"
            preserveAspectRatio="xMidYMid slice"
          >
            <defs>
              <pattern id={patternId} x="0" y="0" width="18" height="18" patternUnits="userSpaceOnUse">
                <circle cx="3" cy="3" r="1.2" fill={`rgba(${tint}, 0.55)`} />
              </pattern>
            </defs>

            <circle cx="200" cy="120" r="90" fill={`url(#${patternId})`} opacity="0.65" />

            <path
              d="M 60 280 Q 110 220, 170 260 T 280 250"
              stroke={`rgba(${tint}, 0.9)`}
              stroke-width="2"
              stroke-linecap="round"
              fill="none"
            />
            <circle cx="280" cy="250" r="5" fill={`rgba(${tint}, 1)`} />

            <g
              stroke={`rgba(${tint}, 0.4)`}
              stroke-width="1.2"
              stroke-linecap="round"
              fill="none"
            >
              <line x1="40" y1="60" x2="80" y2="60" />
              <line x1="40" y1="80" x2="65" y2="80" />
              <line x1="40" y1="100" x2="55" y2="100" />
            </g>

            <text
              x="40"
              y="370"
              font-family="Playfair Display, serif"
              font-size="100"
              font-weight="900"
              fill={`rgba(${tint}, 0.35)`}
              font-style="italic"
            >
              {indexLabel}
            </text>
          </svg>
        </div>
      </div>
    </article>
  )
}

{
  variant === "default" && (
    <a
      href={`/blog/${slug}`}
      class="group flex h-full flex-col gap-5"
    >
      <div
        class="relative h-44 w-full overflow-hidden rounded-2xl border border-line"
        style={`background: radial-gradient(circle at 20% 20%, rgba(${tint}, 0.18) 0%, rgba(${tint}, 0.04) 45%, var(--color-surface) 80%);`}
      >
        <svg
          aria-hidden="true"
          class="absolute inset-0 h-full w-full opacity-40"
          viewBox="0 0 200 110"
          fill="none"
          preserveAspectRatio="xMidYMid slice"
        >
          <defs>
            <pattern id={patternId} x="0" y="0" width="14" height="14" patternUnits="userSpaceOnUse">
              <circle cx="2" cy="2" r="0.8" fill={`rgba(${tint}, 0.5)`} />
            </pattern>
          </defs>
          <rect width="200" height="110" fill={`url(#${patternId})`} opacity="0.5" />
          <path
            d="M 130 80 Q 150 50, 170 70 T 200 60"
            stroke={`rgba(${tint}, 0.85)`}
            stroke-width="1.2"
            stroke-linecap="round"
            fill="none"
          />
          <circle cx="195" cy="58" r="2" fill={`rgba(${tint}, 1)`} />
        </svg>
        <div class="absolute left-5 top-4 font-mono text-[10px] uppercase tracking-[0.3em] text-mute">
          / {indexLabel}
        </div>
        <div
          class="absolute bottom-4 left-5 font-serif text-3xl font-bold italic"
          style={`color: rgba(${tint}, 0.85);`}
        >
          {category}
        </div>
      </div>

      <div class="flex flex-1 flex-col gap-3 px-1">
        <div class="flex items-center gap-3 font-mono text-[10px] uppercase tracking-[0.25em] text-mute-dim">
          <span>{dateFormatted}</span>
          <span aria-hidden="true">·</span>
          <span>{readingMinutes} min</span>
        </div>
        <h3 class="font-serif text-xl font-bold leading-[1.15] text-bone transition-colors group-hover:text-neon md:text-[1.4rem]">
          {title}
        </h3>
        <p class="line-clamp-3 flex-1 text-sm leading-relaxed text-mute">
          {description}
        </p>
        <span class="mt-auto inline-flex items-center gap-2 pt-2 font-mono text-[10px] uppercase tracking-[0.28em] text-bone transition-colors group-hover:text-neon">
          Leer artículo
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
        </span>
      </div>
    </a>
  )
}

{
  variant === "compact" && (
    <a
      href={`/blog/${slug}`}
      class="group grid grid-cols-[auto_1fr_auto] items-start gap-4 border-b border-line py-5 transition-colors hover:bg-surface/40 md:gap-8 md:py-6"
    >
      <span class="mt-0.5 font-mono text-[10px] uppercase tracking-[0.25em] text-mute-dim">
        / {indexLabel}
      </span>
      <div>
        <div class="mb-2 flex items-center gap-3">
          <CategoryBadge category={category} />
          <span class="hidden font-mono text-[10px] uppercase tracking-[0.2em] text-mute-dim sm:inline">
            {dateFormatted}
          </span>
        </div>
        <h4 class="font-serif text-lg font-bold leading-tight text-bone transition-colors group-hover:text-neon md:text-xl">
          {title}
        </h4>
      </div>
      <span
        aria-hidden="true"
        class="mt-2 font-mono text-[10px] uppercase tracking-[0.25em] text-mute transition-colors group-hover:text-neon"
      >
        →
      </span>
    </a>
  )
}
