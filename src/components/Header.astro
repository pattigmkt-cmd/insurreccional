---
import FloatingDock from "./fx/FloatingDock";
import TextShimmer from "./fx/text/TextShimmer";

const pathname = Astro.url.pathname;
const isActive = (path: string) =>
  path === "/" ? pathname === "/" : pathname.startsWith(path);

const links = [
  { href: "/", label: "Inicio" },
  { href: "/blog", label: "Archivo" },
  { href: "/manifiesto", label: "Manifiesto" },
];

const dockItems = links.map((l) => ({
  ...l,
  icon: l.href === "/" ? "◆" : l.href === "/blog" ? "▣" : "◉",
  active: isActive(l.href),
}));
---

<header class="relative z-50 border-b border-line bg-ink/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 w-full max-w-6xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <!-- Logo + TextShimmer (radar sweep removido) -->
    <a href="/" class="group flex items-center gap-3" aria-label="Insurreccional · inicio">
      <span class="relative inline-flex h-7 w-7 items-center justify-center overflow-hidden rounded-full border border-neon/60 bg-neon/10 font-mono text-[10px] font-semibold uppercase tracking-widest text-neon transition-colors group-hover:bg-neon group-hover:text-ink">
        I
      </span>
      <span class="flex flex-col leading-none">
        <TextShimmer
          client:load
          text="Insurreccional"
          as="span"
          duration={3.5}
          className="font-serif text-lg font-bold italic"
        />
        <span class="mt-0.5 font-mono text-[9px] uppercase tracking-[0.3em] text-mute">
          Dominique Alexia
        </span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-8 md:flex" aria-label="Navegación principal">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "relative font-mono text-[11px] uppercase tracking-[0.28em] transition-colors",
              isActive(l.href) ? "text-bone" : "text-mute hover:text-bone",
            ]}
          >
            {l.label}
            {isActive(l.href) && (
              <span
                aria-hidden="true"
                class="absolute -bottom-1 left-0 right-0 h-[1px] bg-neon"
              />
            )}
          </a>
        ))
      }
    </nav>

    <!-- Mobile: minimal icon for small screens -->
    <span class="md:hidden font-mono text-[10px] uppercase tracking-widest text-mute-dim">
      Menu ↓
    </span>
  </div>
</header>

<!-- FloatingDock for mobile (bottom nav) -->
<FloatingDock client:load items={dockItems} />
