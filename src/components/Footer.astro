---
const year = new Date().getFullYear();
---

<!--
  Slim fixed footer (desktop only).
  Why: always-visible brand + key links, sin tapar contenido.
  Mobile usa FloatingDock — este footer queda oculto en mobile.
-->
<footer
  class="fixed bottom-0 left-0 right-0 z-40 hidden h-12 items-center border-t border-line bg-ink/85 px-6 backdrop-blur-md md:flex"
  role="contentinfo"
>
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-6">
    <div class="flex items-center gap-3">
      <span
        class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-neon/60 bg-neon/10 font-mono text-[9px] font-semibold uppercase tracking-widest text-neon"
        aria-hidden="true"
      >
        I
      </span>
      <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-mute">
        © {year} · Insurreccional · Dominique Alexia
      </span>
    </div>

    <nav
      class="flex items-center gap-6 font-mono text-[10px] uppercase tracking-[0.22em]"
      aria-label="Navegación de pie de página"
    >
      <a href="/blog" class="text-mute transition-colors hover:text-bone">Archivo</a>
      <a href="/manifiesto" class="text-mute transition-colors hover:text-bone">Manifiesto</a>
      <span class="text-mute-dim">Buenos Aires · Madrid</span>
    </nav>
  </div>
</footer>

<!-- Spacer para que el contenido no quede oculto detrás del footer en desktop -->
<div aria-hidden="true" class="hidden md:block" style="height: 3rem;"></div>
