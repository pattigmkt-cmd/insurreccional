---
interface Props {
  category: string;
  size?: "sm" | "md";
  accent?: boolean;
}

const { category, size = "sm", accent = false } = Astro.props;
const sizeClass = size === "md" ? "text-[11px] px-2.5 py-1" : "text-[10px] px-2 py-0.5";
---

<span
  class:list={[
    "inline-flex items-center gap-1.5 font-mono uppercase tracking-[0.25em] whitespace-nowrap",
    sizeClass,
    accent
      ? "border border-neon/50 bg-neon/10 text-neon"
      : "border border-line text-mute",
  ]}
>
  {accent && <span aria-hidden="true" class="h-1 w-1 rounded-full bg-neon" />}
  {category}
</span>
