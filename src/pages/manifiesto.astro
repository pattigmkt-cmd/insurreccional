---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import AuroraMesh from "../components/fx/AuroraMesh";
import BlurFade from "../components/fx/BlurFade";
import ShimmerButton from "../components/fx/ShimmerButton";
import DotPattern from "../components/fx/DotPattern";
import LampEffect from "../components/fx/LampEffect";
import StickyScroll from "../components/fx/StickyScroll";
import Timeline from "../components/fx/Timeline";
import EvervaultCard from "../components/fx/EvervaultCard";

// NEW — Wave 4
import Vortex from "../components/fx/bg/Vortex";
import Beams from "../components/fx/bg/Beams";
import ShootingStars from "../components/fx/bg/ShootingStars";
import GooeyText from "../components/fx/text/GooeyText";
import TextHoverEffect from "../components/fx/text/TextHoverEffect";
import FlipWords from "../components/fx/text/FlipWords";
import ManifiestoCards from "../components/fx/ManifiestoCards";
import Confetti from "../components/fx/Confetti";
import CommandPalette from "../components/landing/CommandPalette";

import { getCollection } from "astro:content";
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const cmdPosts = allPosts.map((p) => ({
  id: p.id,
  title: p.data.title,
  category: p.data.category,
  description: p.data.description,
}));

const title = "Manifiesto · Insurreccional";
const description =
  "Por qué existe Insurreccional, y por qué no es un blog más de marketing digital.";

const tesis = [
  {
    num: "01",
    head: "El logo no es la marca.",
    body:
      "Es un disparador. La marca es la promesa específica que hacés sostenidamente. El resto es diseño gráfico, importante pero posterior. Confundirlos es la estafa más común del rubro.",
  },
  {
    num: "02",
    head: "Comunidad, no audiencia.",
    body:
      "Una audiencia se gasta. Una comunidad se capitaliza. La métrica que importa no es alcance, es permanencia. La pregunta correcta no es cuánta gente te ve, es cuánta gente te recomienda sin que vos lo pidas.",
  },
  {
    num: "03",
    head: "Especialización, no flexibilidad.",
    body:
      "Ser 'multi' es la trampa donde tu carrera se detiene. Las agencias te quieren multi para pagarte menos. El mercado paga especialización. Elegí una cosa, profundizá, cobrá el doble.",
  },
  {
    num: "04",
    head: "El criterio se construye con años.",
    body:
      "No existe el curso de marca de seis horas. No existe el framework que reemplaza haber perdido clientes. Desconfiá de todo lo que te prometa atajos. Los atajos son el contenido que la industria vende, no la realidad del oficio.",
  },
  {
    num: "05",
    head: "Lo que no vendemos.",
    body:
      "No vendemos templates. No vendemos plantillas de Instagram. No vendemos cursos de IA aplicada al marketing. No vendemos la ilusión de que tu marca se resuelve antes del almuerzo. Si eso buscás, este no es tu lugar.",
  },
];

const journeyItems = [
  { num: "I", title: "Leíste el manifiesto", description: "Sabés a qué venís. Estás en el lugar correcto.", status: "done" as const },
  { num: "II", title: "Leíste 3 textos", description: "El criterio empieza a instalarse. Las conversaciones de marketing te chirrían de otra forma.", status: "pending" as const },
  { num: "III", title: "Formás parte", description: "No como suscriptor. Como alguien que piensa diferente el oficio.", status: "pending" as const },
];

const flipKickerWords = ["CAMINOS", "CRITERIO", "OFICIO", "VOCES"];
---

<Layout title={title} description={description}>
  <Header />

  <!-- CommandPalette global (cmd+k) -->
  <CommandPalette client:load posts={cmdPosts} />

  <main class="relative">
    <!-- HERO DEL MANIFIESTO — LampEffect + Vortex + Beams -->
    <section class="relative overflow-hidden border-b border-line px-4 py-24 sm:px-6 md:py-36 lg:px-8">
      <!-- NEW: Vortex denso -->
      <Vortex client:idle className="z-[-1]" dense particleCount={100} />
      <AuroraMesh client:idle dense className="z-[-1]" />
      <DotPattern className="z-[-1]" opacity={0.05} />

      <div class="relative mx-auto max-w-5xl">
        <BlurFade client:visible delay={0} direction="down">
          <p class="mb-8 font-mono text-[11px] uppercase tracking-[0.35em] text-neon">
            [ Manifiesto · v. 001 ]
          </p>
        </BlurFade>

        <LampEffect intensity={0.85} className="py-4">
          <h1 class="font-serif text-5xl font-black leading-[0.95] tracking-tight text-bone sm:text-6xl md:text-[5.5rem] lg:text-[7rem]">
            <BlurFade client:visible delay={0.1} direction="up">
              No se trata<br />
              de{" "}
              <span class="italic text-neon">
                <GooeyText client:visible text="mí." className="inline" />
              </span>
            </BlurFade>
          </h1>
        </LampEffect>

        <BlurFade client:visible delay={0.3} direction="up">
          <p class="mt-12 max-w-2xl font-serif text-xl italic leading-snug text-bone-soft md:text-3xl">
            Se trata del criterio que la industria no te enseña, del oficio que
            LinkedIn banalizó, y de los profesionales del sector que están
            agotados y no encuentran un lugar donde pensar en voz alta sin que
            alguien les venda un curso.
          </p>
        </BlurFade>

        <BlurFade client:visible delay={0.45}>
          <div class="mt-14 flex items-center gap-5">
            <span class="h-[1px] w-16 bg-neon" />
            <p class="font-mono text-[11px] uppercase tracking-[0.3em] text-mute">
              Este es ese lugar.
            </p>
          </div>
        </BlurFade>
      </div>
    </section>

    <!-- POR QUÉ EXISTE + Beams -->
    <section class="relative border-b border-line px-4 py-20 sm:px-6 md:py-28 lg:px-8 overflow-hidden">
      <Beams client:idle className="z-0" count={3} />
      <div class="mx-auto grid max-w-6xl gap-12 md:grid-cols-12 md:gap-16 relative z-10">
        <BlurFade client:visible delay={0} className="md:col-span-4">
          <p class="mb-4 font-mono text-[11px] uppercase tracking-[0.3em] text-neon">
            [ Por qué existe ]
          </p>
          <h2 class="font-serif text-3xl font-bold leading-tight text-bone md:text-4xl">
            La pregunta que nadie se quiere hacer.
          </h2>
        </BlurFade>

        <BlurFade client:visible delay={0.15} className="space-y-6 md:col-span-8">
          <p class="font-serif text-lg leading-relaxed text-bone md:text-xl">
            El marketing digital en español está inundado.
            Gurúes que venden cursos sobre herramientas que no saben usar.
            Agencias que te contratan para hacer de todo y llaman "perfil
            integral" a lo que es explotación.
          </p>
          <p class="text-base leading-relaxed text-bone-soft md:text-lg">
            En el medio queda un vacío. <strong class="text-bone">No hay espacio para pensar despacio sobre
            el oficio</strong>. Para discutir por qué una marca funciona o no, qué
            significa construir comunidad, qué carrera estás construyendo vos
            cuando aceptás ser todo para todos.
          </p>
          <p class="text-base leading-relaxed text-bone-soft md:text-lg">
            Insurreccional existe para ocupar ese vacío. No con una fórmula.
            Con textos largos, preguntas incómodas, y conversaciones con gente
            que trabaja en lo mismo que vos.
          </p>
        </BlurFade>
      </div>
    </section>

    <!-- 5 TESIS — StickyScroll + TextHoverEffect en h2 -->
    <section class="relative border-b border-line px-4 py-20 sm:px-6 md:py-28 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <BlurFade client:visible delay={0}>
          <div class="mb-16 flex items-baseline justify-between gap-6 border-b border-line pb-6">
            <h2 class="font-serif text-3xl font-bold text-bone md:text-5xl">
              <TextHoverEffect client:visible text="Cinco tesis de arranque." className="font-serif text-3xl font-bold md:text-5xl" />
            </h2>
            <span class="font-mono text-[11px] uppercase tracking-[0.3em] text-mute">
              [ 05 / 05 ]
            </span>
          </div>
        </BlurFade>

        <StickyScroll
          client:visible
          items={tesis.map((t) => ({ title: t.head, description: t.body }))}
        />
      </div>
    </section>

    <!-- PARA QUIÉN ES / NO ES — ManifiestoCards (DirectionAwareHover wrapped) -->
    <section class="relative border-b border-line bg-surface/60 px-4 py-20 sm:px-6 md:py-28 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <BlurFade client:visible delay={0}>
          <ManifiestoCards client:visible />
        </BlurFade>
      </div>
    </section>

    <!-- JOURNEY TIMELINE -->
    <section class="relative border-b border-line px-4 py-20 sm:px-6 md:py-24 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <BlurFade client:visible delay={0} className="mb-12">
          <p class="font-mono text-[11px] uppercase tracking-[0.3em] text-mute">
            [ El recorrido típico ]
          </p>
        </BlurFade>
        <Timeline client:visible items={journeyItems} />
      </div>
    </section>

    <!-- CIERRE — EvervaultCard + FlipWords + ShootingStars + Confetti -->
    <section class="relative overflow-hidden px-4 py-28 sm:px-6 md:py-40 lg:px-8">
      <ShootingStars client:visible className="z-0" count={6} />
      <DotPattern className="z-0" opacity={0.05} />
      <div class="relative z-10 mx-auto max-w-3xl text-center">
        <EvervaultCard client:visible large className="mb-12">
          <div class="font-serif text-3xl leading-[1.15] text-bone md:text-5xl py-4">
            <p class="font-serif italic">
              "La industria vende atajos. Nosotras publicamos{" "}
              <FlipWords
                client:visible
                words={flipKickerWords}
                interval={2500}
                className="text-neon not-italic"
              />."
            </p>
          </div>
        </EvervaultCard>

        <BlurFade client:visible delay={0.5}>
          <div class="inline-flex items-center gap-4">
            <span class="h-[1px] w-10 bg-neon" />
            <p class="font-mono text-[11px] uppercase tracking-[0.3em] text-neon">
              Dominique Alexia · Buenos Aires · 2026
            </p>
            <span class="h-[1px] w-10 bg-neon" />
          </div>
        </BlurFade>

        <BlurFade client:visible delay={0.65} className="mt-14">
          <Confetti client:visible count={50}>
            <ShimmerButton client:visible href="/blog">
              Leer los textos
              <span aria-hidden="true">→</span>
            </ShimmerButton>
          </Confetti>
        </BlurFade>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
