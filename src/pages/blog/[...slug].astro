---
import { getCollection, render, type CollectionEntry } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);

// Resolve next post in the chain (if frontmatter `next` is set).
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const nextPost = post.data.next
  ? allPosts.find((p) => p.id === post.data.next)
  : undefined;
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  category={post.data.category}
  kicker={post.data.kicker}
  pubDate={post.data.pubDate}
  readingMinutes={post.data.readingMinutes}
  slug={post.id}
  nextHook={post.data.nextHook}
  nextPost={nextPost
    ? {
        slug: nextPost.id,
        title: nextPost.data.title,
        category: nextPost.data.category,
        readingMinutes: nextPost.data.readingMinutes,
      }
    : undefined}
>
  <Content />
</PostLayout>
