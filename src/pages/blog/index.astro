---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PostCard from "../../components/PostCard.astro";
import CategoryBadge from "../../components/CategoryBadge.astro";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const categories = Array.from(
  new Set(posts.map((p) => p.data.category))
).sort();

const title = "Archivo · Insurreccional";
const description =
  "Todos los textos publicados en Insurreccional. Criterio sobre branding, industria, estrategia y oficio.";
---

<Layout title={title} description={description}>
  <Header />

  <main class="relative">
    <!-- HEADER DEL ARCHIVO -->
    <section class="relative overflow-hidden border-b border-line px-4 py-20 sm:px-6 md:py-28 lg:px-8">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -right-32 top-0 h-[380px] w-[380px] rounded-full opacity-[0.1] blur-[100px]"
        style="background: radial-gradient(circle, #c8ff00 0%, transparent 65%);"
      >
      </div>

      <div class="relative mx-auto max-w-6xl">
        <p class="mb-6 font-mono text-[11px] uppercase tracking-[0.3em] text-neon">
          [ Archivo editorial ]
        </p>
        <div class="grid gap-8 md:grid-cols-12 md:gap-10">
          <h1 class="font-serif text-5xl font-bold leading-[0.95] text-bone sm:text-6xl md:col-span-8 md:text-7xl lg:text-[6.5rem]">
            El archivo<span class="text-neon">.</span>
          </h1>
          <div class="flex flex-col justify-end md:col-span-4">
            <p class="text-base leading-relaxed text-mute md:text-lg">
              {posts.length} {posts.length === 1 ? "texto publicado" : "textos publicados"} ·
              {categories.length} {categories.length === 1 ? "categoría" : "categorías"}
            </p>
            <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.25em] text-mute-dim">
              Orden cronológico inverso
            </p>
          </div>
        </div>

        <!-- Filtro de categorías (anchors, zero JS) -->
        <div class="mt-16 flex flex-wrap items-center gap-2 border-t border-line pt-8">
          <span class="mr-3 font-mono text-[10px] uppercase tracking-[0.3em] text-mute">
            Categorías:
          </span>
          <a href="#todos" class="transition-colors">
            <CategoryBadge category="Todos" accent />
          </a>
          {
            categories.map((c) => (
              <a href={`#${c.toLowerCase()}`} class="transition-colors">
                <CategoryBadge category={c} />
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- LISTADO DE POSTS -->
    <section id="todos" class="relative px-4 py-20 sm:px-6 md:py-28 lg:px-8">
      <div class="mx-auto max-w-6xl">
        {
          categories.map((category) => {
            const inCat = posts.filter((p) => p.data.category === category);
            return (
              <div id={category.toLowerCase()} class="mb-20 scroll-mt-24 md:mb-28">
                <header class="mb-8 flex items-baseline justify-between gap-6 border-b border-line pb-4">
                  <h2 class="font-serif text-3xl font-bold italic text-bone md:text-4xl">
                    {category}
                  </h2>
                  <span class="font-mono text-[11px] uppercase tracking-[0.25em] text-mute">
                    {String(inCat.length).padStart(2, "0")} texto{inCat.length !== 1 ? "s" : ""}
                  </span>
                </header>

                <div class="divide-y divide-line">
                  {inCat.map((post, i) => (
                    <PostCard
                      slug={post.id}
                      title={post.data.title}
                      description={post.data.description}
                      kicker={post.data.kicker}
                      category={post.data.category}
                      pubDate={post.data.pubDate}
                      readingMinutes={post.data.readingMinutes}
                      variant="compact"
                      index={i}
                    />
                  ))}
                </div>
              </div>
            );
          })
        }
      </div>
    </section>
  </main>

  <Footer />
</Layout>
