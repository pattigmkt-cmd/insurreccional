---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import BlogArchiveClient from "../../components/BlogArchiveClient";

import Meteors from "../../components/fx/Meteors";
import DotPattern from "../../components/fx/DotPattern";
import BlurFade from "../../components/fx/BlurFade";
import NumberTicker from "../../components/fx/NumberTicker";
import LampEffect from "../../components/fx/LampEffect";
import TracingBeam from "../../components/fx/TracingBeam";

// NEW — Wave 4
import FlickeringGrid from "../../components/fx/bg/FlickeringGrid";
import BackgroundBoxes from "../../components/fx/bg/BackgroundBoxes";
import TextShimmer from "../../components/fx/text/TextShimmer";
import CommandPalette from "../../components/landing/CommandPalette";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const categories = Array.from(
  new Set(posts.map((p) => p.data.category))
).sort();

const title = "Archivo · Insurreccional";
const description =
  "Todos los textos publicados en Insurreccional. Criterio sobre branding, industria, estrategia y oficio.";

const serializedPosts = posts.map((p) => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description,
  category: p.data.category,
  kicker: p.data.kicker,
  readingMinutes: p.data.readingMinutes,
  pubDate: p.data.pubDate.toISOString(),
}));

const cmdPosts = allPosts.map((p) => ({
  id: p.id,
  title: p.data.title,
  category: p.data.category,
  description: p.data.description,
}));
---

<Layout title={title} description={description}>
  <Header />

  <!-- CommandPalette global (cmd+k) -->
  <CommandPalette client:load posts={cmdPosts} />

  <main class="relative">
    <!-- HEADER DEL ARCHIVO + FlickeringGrid -->
    <section class="relative overflow-hidden border-b border-line px-4 py-20 sm:px-6 md:py-28 lg:px-8">
      <DotPattern className="z-0" opacity={0.07} />
      <!-- NEW: flickering grid as bg -->
      <FlickeringGrid client:idle className="z-0" cellSize={24} flickerChance={0.004} opacity={0.05} />
      <Meteors client:visible count={8} className="z-0" />

      <div class="relative z-10 mx-auto max-w-6xl">
        <BlurFade client:visible delay={0} direction="down">
          <p class="mb-6 font-mono text-[11px] uppercase tracking-[0.3em] text-neon">
            [ Archivo editorial ]
          </p>
        </BlurFade>

        <LampEffect intensity={0.75} className="py-4">
          <div class="grid gap-8 md:grid-cols-12 md:gap-10">
            <BlurFade client:visible delay={0.1} className="md:col-span-8">
              <h1 class="font-serif text-5xl font-bold leading-[0.95] text-bone sm:text-6xl md:text-7xl lg:text-[6.5rem]">
                El archivo<span class="text-neon">.</span>
              </h1>
            </BlurFade>

            <BlurFade client:visible delay={0.25} className="flex flex-col justify-end md:col-span-4">
              <p class="text-base leading-relaxed text-mute md:text-lg">
                <NumberTicker client:visible value={posts.length} suffix={posts.length === 1 ? " texto publicado" : " textos publicados"} />
                {" "}·{" "}
                <NumberTicker client:visible value={categories.length} suffix={categories.length === 1 ? " categoría" : " categorías"} />
              </p>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.25em] text-mute-dim">
                Orden cronológico inverso
              </p>
            </BlurFade>
          </div>
        </LampEffect>

        {/* Category shimmer labels */}
        <BlurFade client:visible delay={0.4}>
          <div class="mt-6 flex flex-wrap gap-4">
            {categories.map((cat) => (
              <TextShimmer client:visible text={cat} as="span" duration={3} className="font-mono text-[10px] uppercase tracking-[0.25em]" />
            ))}
          </div>
        </BlurFade>
      </div>
    </section>

    <!-- BackgroundBoxes divider (desktop only) -->
    <div class="relative border-b border-line h-20 overflow-hidden hidden md:block" aria-hidden="true">
      <BackgroundBoxes client:idle rows={4} cols={24} className="z-0" />
    </div>

    <!-- LISTADO DE POSTS — TracingBeam + BlogArchiveClient -->
    <section class="relative px-4 py-20 sm:px-6 md:py-28 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <TracingBeam client:visible>
          <BlogArchiveClient
            client:visible
            posts={serializedPosts}
            categories={categories}
          />
        </TracingBeam>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
