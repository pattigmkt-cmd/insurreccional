---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PostCard from "../../components/PostCard.astro";
import BlogArchiveClient from "../../components/BlogArchiveClient";

import BlurFade from "../../components/fx/BlurFade";
import CommandPalette from "../../components/landing/CommandPalette";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sorted = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const featured = sorted.find((p) => p.data.featured) ?? sorted[0];
const rest = sorted.filter((p) => p.id !== featured?.id);

const categories = Array.from(
  new Set(sorted.map((p) => p.data.category))
).sort();

const title = "Blog · Insurreccional";
const description =
  "Criterio editorial sobre branding, industria, estrategia y oficio. Sin filtros agencia ni promesas vacías.";

const serializedPosts = rest.map((p) => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description,
  category: p.data.category,
  kicker: p.data.kicker,
  readingMinutes: p.data.readingMinutes,
  pubDate: p.data.pubDate.toISOString(),
}));

const cmdPosts = sorted.map((p) => ({
  id: p.id,
  title: p.data.title,
  category: p.data.category,
  description: p.data.description,
}));
---

<Layout title={title} description={description}>
  <Header />

  <CommandPalette client:load posts={cmdPosts} />

  <main class="relative">
    <section class="relative px-4 pt-16 sm:px-6 md:pt-24 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <BlurFade client:visible delay={0} direction="down">
          <p class="mb-8 font-mono text-[11px] uppercase tracking-[0.3em] text-neon">
            [ Archivo editorial ]
          </p>
        </BlurFade>

        <BlurFade client:visible delay={0.1}>
          <div class="flex flex-wrap items-center gap-6 md:gap-10">
            <h1 class="font-serif text-7xl font-bold leading-[0.92] text-bone sm:text-8xl md:text-[9rem] lg:text-[11rem]">
              Blog<span class="text-neon">.</span>
            </h1>

            <svg
              aria-hidden="true"
              class="hidden text-neon sm:block"
              width="180"
              height="90"
              viewBox="0 0 180 90"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
            >
              <path d="M 8 55 Q 28 18, 50 50 T 95 50 T 140 45" />
              <circle cx="160" cy="32" r="5" fill="currentColor" stroke="none" />
              <path
                d="M 18 72 Q 35 65, 55 70"
                stroke-width="1.5"
                opacity="0.5"
              />
            </svg>
          </div>
        </BlurFade>

        <BlurFade client:visible delay={0.25}>
          <p class="mt-8 max-w-xl text-base leading-relaxed text-mute md:text-lg">
            {sorted.length} {sorted.length === 1 ? "texto publicado" : "textos publicados"} en {categories.length} {categories.length === 1 ? "categoría" : "categorías"}. Orden cronológico inverso.
          </p>
        </BlurFade>
      </div>
    </section>

    {featured && (
      <section class="relative px-4 py-16 sm:px-6 md:py-24 lg:px-8">
        <div class="mx-auto max-w-6xl">
          <BlurFade client:visible delay={0.1}>
            <PostCard
              variant="feature"
              slug={featured.id}
              title={featured.data.title}
              description={featured.data.description}
              kicker={featured.data.kicker}
              category={featured.data.category}
              pubDate={featured.data.pubDate}
              readingMinutes={featured.data.readingMinutes}
              index={0}
            />
          </BlurFade>
        </div>
      </section>
    )}

    <section class="relative px-4 pb-32 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <BlurFade client:visible delay={0.1}>
          <div class="mb-10 flex items-baseline justify-between gap-6 border-b border-line pb-5">
            <h2 class="font-serif text-2xl font-bold text-bone md:text-3xl">
              Todos los textos
            </h2>
            <span class="font-mono text-[10px] uppercase tracking-[0.25em] text-mute">
              {String(rest.length).padStart(2, "0")} {rest.length === 1 ? "texto" : "textos"}
            </span>
          </div>
        </BlurFade>

        <BlogArchiveClient
          client:visible
          posts={serializedPosts}
          categories={categories}
        />
      </div>
    </section>
  </main>

  <Footer />
</Layout>
