---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PostCard from "../components/PostCard.astro";

// FX Components
import AuroraMesh from "../components/fx/AuroraMesh";
import SplitText from "../components/fx/SplitText";
import BlurFade from "../components/fx/BlurFade";
import Marquee from "../components/fx/Marquee";
import ShimmerButton from "../components/fx/ShimmerButton";
import MagneticButton from "../components/fx/MagneticButton";
import SpotlightCard from "../components/fx/SpotlightCard";
import CardTilt from "../components/fx/CardTilt";
import BorderBeam from "../components/fx/BorderBeam";
import NumberTicker from "../components/fx/NumberTicker";
import DotPattern from "../components/fx/DotPattern";
import RetroGrid from "../components/fx/RetroGrid";
import LampEffect from "../components/fx/LampEffect";
import AnimatedGradientText from "../components/fx/AnimatedGradientText";
import InfiniteQuotes from "../components/fx/InfiniteQuotes";
import HoverRevealCard from "../components/fx/HoverRevealCard";
import Timeline from "../components/fx/Timeline";
import EvervaultCard from "../components/fx/EvervaultCard";

// NEW — Wave 4
import Beams from "../components/fx/bg/Beams";
import Sparkles from "../components/fx/bg/Sparkles";
import ShootingStars from "../components/fx/bg/ShootingStars";
import Typewriter from "../components/fx/text/Typewriter";
import TextShimmer from "../components/fx/text/TextShimmer";
import AnimatedBeam from "../components/fx/AnimatedBeam";
import FocusCards from "../components/fx/FocusCards";
import StatsBlock from "../components/landing/StatsBlock";
import AboutPanel from "../components/landing/AboutPanel";
import ReaderTestimonials from "../components/landing/ReaderTestimonials";
import NewsletterSignup from "../components/landing/NewsletterSignup";
import CommandPalette from "../components/landing/CommandPalette";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const featured = allPosts
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const totalPosts = allPosts.length;

const title = "Insurreccional · Criterio sobre branding por Dominique Alexia";
const description =
  "Plataforma editorial sobre branding para profesionales quemados del sector. Criterio real — no logos, no seguidores, no cursos de IA. Por Dominique Alexia.";

const marqueeItems = [
  "No vendemos cursos",
  "No vendemos templates",
  "No vendemos fórmulas",
  "Comunidad antes que audiencia",
  "Criterio antes que crecimiento",
  "Profundidad antes que alcance",
  "Construido despacio",
];

const quotes = [
  { quote: "El logo viene al final. Cuando viene al final, es trivial.", author: "Tu logo no es tu marca" },
  { quote: "El perfil integral no existe. Existe el perfil explotado.", author: "Multitasking" },
  { quote: "Una audiencia se gasta. Una comunidad se capitaliza.", author: "Comunidad antes que audiencia" },
  { quote: "Construir comunidad es lento. Un año, dos años, tres.", author: "Comunidad" },
  { quote: "La coherencia es más importante que la creatividad.", author: "Logo no es marca" },
];

const timelineItems = [
  { num: "01", title: "Blog", description: "El núcleo. Textos largos, sin resumen ejecutivo. Para leer despacio en una pausa real, no entre un mensaje de WhatsApp y otro.", status: "active" as const },
  { num: "02", title: "YouTube", description: "Ensayos en video. Formato largo. Sin cortes cada ocho segundos. Sin edición de TikTok aplicada a contenido que necesita respirar.", status: "pending" as const },
  { num: "03", title: "Podcast", description: "Conversaciones con gente real del sector. No gurúes, no 'expertos' con 300k followers y cero clientes. Profesionales que saben porque hicieron.", status: "pending" as const },
];

const noSellItems = ["Templates", "Cursos de IA", "Fórmulas mágicas", "Resultados en 30 días"];

const kickerVariants = [
  "Edición 001 · Abril 2026 · Plataforma editorial",
  "Criterio antes que crecimiento · Plataforma editorial",
  "Sin cursos. Sin fórmulas. · Plataforma editorial",
];

const cmdPosts = allPosts.map((p) => ({
  id: p.id,
  title: p.data.title,
  category: p.data.category,
  description: p.data.description,
}));
---

<Layout title={title} description={description}>
  <Header />

  <!-- CommandPalette global (cmd+k) -->
  <CommandPalette client:load posts={cmdPosts} />

  <main>
    <!-- ═══════════════════════════════════════════════════════
         HERO — LampEffect wrapping h1
    ═══════════════════════════════════════════════════════ -->
    <section class="relative isolate overflow-hidden border-b border-line px-4 pb-28 pt-20 sm:px-6 md:pb-36 md:pt-28 lg:px-8">
      <!-- Aurora Mesh background -->
      <AuroraMesh client:idle className="z-[-1]" />
      <!-- NEW: Beams crossing -->
      <Beams client:idle className="z-[-1]" count={4} />
      <!-- NEW: Sparkles layer -->
      <Sparkles client:idle className="z-[-1]" density={50} />
      <!-- Retro grid at bottom -->
      <RetroGrid className="z-[-1] opacity-60" />
      <!-- Dot pattern -->
      <DotPattern className="z-[-1]" opacity={0.06} />

      <div class="relative mx-auto max-w-6xl">
        <BlurFade client:visible delay={0} direction="down">
          <p class="mb-8 flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.35em] text-mute">
            <span class="inline-block h-2 w-2 animate-pulse rounded-full bg-neon" />
            <Typewriter
              client:visible
              texts={kickerVariants}
              speed={50}
              deleteSpeed={30}
              pauseMs={2500}
            />
          </p>
        </BlurFade>

        <!-- LampEffect on the h1 -->
        <LampEffect className="py-4" intensity={1.2}>
          <h1 class="font-serif text-[19vw] font-black leading-[0.85] tracking-[-0.03em] text-bone sm:text-[14vw] md:text-[10.5vw] lg:text-[8.2rem]">
            <SplitText
              client:visible
              text="Insurreccional."
              as="span"
              delay={0.1}
              staggerDelay={0.03}
              className="block"
            />
          </h1>
        </LampEffect>

        <div class="mt-10 grid gap-10 md:grid-cols-12 md:gap-12">
          <BlurFade client:visible delay={0.25} direction="up" className="md:col-span-7">
            <p class="font-serif text-xl italic leading-snug text-bone md:text-3xl">
              <AnimatedGradientText client:visible className="font-serif text-xl italic leading-snug md:text-3xl" speed={6}>
                <TextShimmer client:visible text="No te enseño herramientas. No te mando templates. Te doy el criterio que tardé una década construir" as="span" duration={3} />
              </AnimatedGradientText>
              {" "}<span class="text-bone-soft">— y que la industria te vende en
              cursos de una hora con promesa de viralidad.</span>
            </p>
          </BlurFade>

          <BlurFade client:visible delay={0.4} direction="up" className="flex flex-col justify-end gap-6 md:col-span-5">
            <div class="border-l border-line pl-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-mute">
                Para quién
              </p>
              <p class="mt-2 text-sm leading-relaxed text-bone-soft">
                Diseñadoras, community managers, social media managers a las
                que les piden hacer de todo. Consultoras jóvenes. Profesionales
                del sector, quemados.
              </p>
            </div>
            <div class="border-l border-neon pl-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-neon">
                Para qué
              </p>
              <p class="mt-2 text-sm leading-relaxed text-bone-soft">
                Construir comunidad antes que audiencia. Criterio antes que
                crecimiento. Profundidad antes que alcance.
              </p>
            </div>
          </BlurFade>
        </div>

        <!-- CTA -->
        <BlurFade client:visible delay={0.55} direction="up" className="mt-16 flex flex-col items-start gap-6 sm:flex-row sm:items-center">
          <ShimmerButton client:visible href="/blog">
            Entrar al archivo
            <span aria-hidden="true">→</span>
          </ShimmerButton>
          <MagneticButton client:visible href="/manifiesto">
            Leer el manifiesto
            <span aria-hidden="true" class="opacity-60">↗</span>
          </MagneticButton>
        </BlurFade>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         MARQUEE DIVIDER
    ═══════════════════════════════════════════════════════ -->
    <div class="border-b border-line bg-surface/40 py-5 overflow-hidden">
      <Marquee client:visible speed={35} pauseOnHover className="gap-0">
        {marqueeItems.map((item) => (
          <span class="font-serif text-lg italic text-bone/60 whitespace-nowrap">
            {item}
            <span class="mx-8 text-neon/40 not-italic">·</span>
          </span>
        ))}
      </Marquee>
    </div>

    <!-- ═══════════════════════════════════════════════════════
         STATS BLOCK — NEW
    ═══════════════════════════════════════════════════════ -->
    <StatsBlock client:visible />

    <!-- ═══════════════════════════════════════════════════════
         VOCES — InfiniteQuotes
    ═══════════════════════════════════════════════════════ -->
    <section class="relative border-b border-line overflow-hidden py-16 md:py-24">
      <BlurFade client:visible delay={0} className="mb-10 px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-6xl flex items-center justify-between gap-6">
          <p class="font-mono text-[11px] uppercase tracking-[0.3em] text-neon">
            [ Voces del archivo ]
          </p>
          <span class="h-[1px] flex-1 bg-line/60 max-w-xs" />
        </div>
      </BlurFade>
      <div class="space-y-4">
        <InfiniteQuotes client:visible items={quotes} speed={45} direction="normal" />
        <InfiniteQuotes client:visible items={[...quotes].reverse()} speed={35} direction="reverse" />
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         FEATURED POSTS — Bento asimétrico + FocusCards
    ═══════════════════════════════════════════════════════ -->
    <section class="relative border-b border-line px-4 py-24 sm:px-6 md:py-32 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <BlurFade client:visible delay={0} className="mb-16">
          <div class="grid gap-8 md:grid-cols-12 md:items-end md:gap-10">
            <div class="md:col-span-8">
              <p class="mb-4 font-mono text-[11px] uppercase tracking-[0.3em] text-neon">
                [ Últimas publicaciones ]
              </p>
              <h2 class="font-serif text-4xl font-bold leading-[1.02] text-bone sm:text-5xl md:text-6xl">
                Los textos que te incomodan,<br />
                <span class="italic text-mute">cuando los tengo listos.</span>
              </h2>
            </div>
            <p class="text-sm leading-relaxed text-mute md:col-span-4">
              Se publica cuando hay algo que decir. No cuando el calendario pide.
              Si preferís el ritmo de redes, este lugar no es para vos.
            </p>
          </div>
        </BlurFade>

        {featured.length >= 1 && (
          <BlurFade client:visible delay={0.1} className="mb-6">
            <CardTilt client:visible maxTilt={3}>
              <SpotlightCard client:visible className="group relative overflow-hidden border border-line bg-surface/70 p-8 transition-colors hover:border-neon/30 md:p-12">
                <BorderBeam client:visible />
                <div class="grid gap-8 md:grid-cols-12 md:gap-10">
                  <div class="md:col-span-5">
                    <div class="flex items-center gap-3">
                      <span class="font-mono text-[11px] uppercase tracking-[0.3em] text-neon">
                        [ 01 ] Destacado
                      </span>
                    </div>
                    <div class="mt-5">
                      <span class="inline-block border border-neon/40 px-2.5 py-1 font-mono text-[10px] uppercase tracking-[0.25em] text-neon">
                        {featured[0].data.category}
                      </span>
                    </div>
                    <p class="mt-5 font-mono text-[11px] uppercase tracking-[0.2em] text-mute">
                      {featured[0].data.pubDate.toLocaleDateString("es-AR", { year: "numeric", month: "long", day: "numeric" })} · {featured[0].data.readingMinutes} min
                    </p>
                  </div>
                  <a href={`/blog/${featured[0].id}`} class="md:col-span-7">
                    {featured[0].data.kicker && (
                      <p class="mb-3 font-serif text-sm italic text-mute">
                        — {featured[0].data.kicker}
                      </p>
                    )}
                    <h2 class="font-serif text-3xl font-bold leading-[1.05] text-bone transition-colors group-hover:text-neon sm:text-4xl md:text-5xl">
                      {featured[0].data.title}
                    </h2>
                    <p class="mt-5 max-w-xl text-base leading-relaxed text-bone-soft md:text-lg">
                      {featured[0].data.description}
                    </p>
                    <span class="mt-8 inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.28em] text-bone transition-colors group-hover:text-neon">
                      Leer completo
                      <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
                    </span>
                  </a>
                </div>
              </SpotlightCard>
            </CardTilt>
          </BlurFade>
        )}

        {featured.length >= 3 && (
          <!-- Bento: 2 posts chicos — FocusCards wrapper + HoverRevealCard -->
          <FocusCards client:visible className="grid gap-6 md:grid-cols-2">
            {[featured[1], featured[2]].map((post, i) => (
              <BlurFade client:visible delay={0.2 + i * 0.1}>
                <HoverRevealCard
                  client:visible
                  href={`/blog/${post.id}`}
                  title={post.data.title}
                  subtitle={post.data.kicker}
                  description={post.data.description}
                  category={post.data.category}
                  meta={`${post.data.readingMinutes} min`}
                  className="h-full"
                />
              </BlurFade>
            ))}
          </FocusCards>
        )}

        {featured.length > 0 && featured.length < 3 && (
          <div class="space-y-16 md:space-y-20 mt-6">
            {featured.slice(1).map((post, i) => (
              <PostCard
                slug={post.id}
                title={post.data.title}
                description={post.data.description}
                kicker={post.data.kicker}
                category={post.data.category}
                pubDate={post.data.pubDate}
                readingMinutes={post.data.readingMinutes}
                variant="feature"
                index={i + 1}
              />
            ))}
          </div>
        )}

        <BlurFade client:visible delay={0.3} className="mt-20 flex justify-center">
          <a
            href="/blog"
            class="group inline-flex items-center gap-3 border border-line bg-surface px-6 py-3 font-mono text-[11px] uppercase tracking-[0.28em] text-bone transition-colors hover:border-neon/60 hover:text-neon"
          >
            Ver archivo completo
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
          </a>
        </BlurFade>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         DE QUÉ TRATA ESTO — Timeline
    ═══════════════════════════════════════════════════════ -->
    <section class="relative border-b border-line px-4 py-24 sm:px-6 md:py-32 lg:px-8">
      <div class="mx-auto grid max-w-6xl gap-14 md:grid-cols-12 md:gap-20">
        <BlurFade client:visible delay={0} className="md:col-span-5">
          <p class="mb-6 font-mono text-[11px] uppercase tracking-[0.3em] text-mute">
            [ De qué trata esto ]
          </p>
          <h2 class="font-serif text-4xl font-bold leading-[1.05] text-bone sm:text-5xl">
            Una plataforma,<br />
            <span class="italic text-neon">tres canales.</span>
          </h2>
          <p class="mt-6 max-w-sm text-sm leading-relaxed text-mute">
            Arranca en texto — porque escribir obliga a pensar. Crece en video
            y podcast. Pero la base siempre va a ser esto.
          </p>
          <p class="mt-8 font-mono text-[11px] uppercase tracking-[0.25em] text-mute-dim">
            <NumberTicker client:visible value={totalPosts} suffix=" textos publicados" />
          </p>
        </BlurFade>

        <div class="md:col-span-7">
          <Timeline client:visible items={timelineItems} />
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         LO QUE NO VENDEMOS — EvervaultCard grid
    ═══════════════════════════════════════════════════════ -->
    <section class="relative border-b border-line px-4 py-24 sm:px-6 md:py-32 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <BlurFade client:visible delay={0} className="mb-16">
          <p class="mb-4 font-mono text-[11px] uppercase tracking-[0.3em] text-mute">
            [ Lo que NO vendemos ]
          </p>
          <h2 class="font-serif text-4xl font-bold leading-[1.05] text-bone sm:text-5xl">
            Nunca vas a ver esto<br />
            <span class="italic text-mute">en Insurreccional.</span>
          </h2>
        </BlurFade>

        <div class="grid gap-4 sm:grid-cols-2">
          {noSellItems.map((item) => (
            <BlurFade client:visible delay={0.1}>
              <EvervaultCard client:visible className="min-h-[120px] flex items-center justify-center">
                <p class="font-serif text-2xl font-bold text-bone md:text-3xl text-center">
                  <span class="line-through text-mute/60">{item}</span>
                </p>
              </EvervaultCard>
            </BlurFade>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         ABOUT PANEL — NEW
    ═══════════════════════════════════════════════════════ -->
    <AboutPanel client:visible />

    <!-- ═══════════════════════════════════════════════════════
         READER TESTIMONIALS — NEW
    ═══════════════════════════════════════════════════════ -->
    <ReaderTestimonials client:visible />

    <!-- ═══════════════════════════════════════════════════════
         CIERRE QUOTE — LampEffect + EvervaultCard + ShootingStars
    ═══════════════════════════════════════════════════════ -->
    <section class="relative border-t border-line bg-surface/50 px-4 py-24 sm:px-6 md:py-32 lg:px-8 overflow-hidden">
      <ShootingStars client:visible className="z-0" count={5} />
      <DotPattern className="z-0" opacity={0.05} />
      <div class="relative z-10 mx-auto max-w-4xl text-center">
        <p class="mb-6 font-mono text-[10px] uppercase tracking-[0.35em] text-neon">
          · · ·
        </p>

        <LampEffect intensity={0.9} className="py-10">
          <EvervaultCard client:visible large className="border-0 bg-transparent text-center">
            <div class="font-serif text-3xl leading-[1.2] text-bone md:text-5xl">
              <SplitText
                client:visible
                text='"Construir marca no es aprender una herramienta — es aprender a elegir qué no hacés."'
                as="p"
                delay={0}
                staggerDelay={0.018}
                className="font-serif italic"
              />
            </div>
          </EvervaultCard>
        </LampEffect>

        <BlurFade client:visible delay={0.4}>
          <p class="mt-10 font-mono text-[11px] uppercase tracking-[0.3em] text-mute">
            Dominique Alexia
          </p>
        </BlurFade>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         NEWSLETTER — NEW
    ═══════════════════════════════════════════════════════ -->
    <NewsletterSignup client:visible />
  </main>

  <Footer />
</Layout>
