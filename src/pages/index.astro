---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PostCard from "../components/PostCard.astro";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const featured = allPosts
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const title = "Insurreccional · Criterio sobre branding por Dominique Alexia";
const description =
  "Plataforma editorial sobre branding para profesionales quemados del sector. Criterio real — no logos, no seguidores, no cursos de IA. Por Dominique Alexia.";
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <!-- HERO -->
    <section
      class="relative isolate overflow-hidden border-b border-line px-4 pb-24 pt-20 sm:px-6 md:pb-32 md:pt-28 lg:px-8"
    >
      <!-- Retícula tenue de fondo -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 opacity-[0.05]"
        style="background-image: linear-gradient(to right, #fff 1px, transparent 1px), linear-gradient(to bottom, #fff 1px, transparent 1px); background-size: 96px 96px;"
      >
      </div>

      <!-- Halo neón off-center -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -left-20 top-1/4 h-[420px] w-[420px] rounded-full opacity-[0.14] blur-[120px]"
        style="background: radial-gradient(circle, #c8ff00 0%, transparent 65%);"
      >
      </div>

      <div class="relative mx-auto max-w-6xl">
        <p class="mb-8 flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.35em] text-mute fade-up">
          <span class="inline-block h-2 w-2 animate-pulse rounded-full bg-neon" />
          Edición 001 · Abril 2026 · Plataforma editorial
        </p>

        <h1
          class="fade-up font-serif text-[19vw] font-black leading-[0.85] tracking-[-0.03em] text-bone sm:text-[14vw] md:text-[10.5vw] lg:text-[8.2rem]"
        >
          Insu<span class="italic text-neon">rrecc</span>ional<span class="text-neon">.</span>
        </h1>

        <div class="mt-10 grid gap-10 md:grid-cols-12 md:gap-12">
          <p
            class="fade-up font-serif text-xl italic leading-snug text-bone md:col-span-7 md:text-3xl"
            style="animation-delay: 0.15s;"
          >
            No te enseño herramientas. No te mando templates. Te doy el criterio
            que tomé una década construir — y que la industria te vende en
            cursos de una hora con promesa de viralidad.
          </p>

          <div
            class="fade-up flex flex-col justify-end gap-6 md:col-span-5"
            style="animation-delay: 0.3s;"
          >
            <div class="border-l border-line pl-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-mute">
                Para quién
              </p>
              <p class="mt-2 text-sm leading-relaxed text-bone-soft">
                Diseñadoras, community managers, social media managers a las
                que les piden hacer de todo. Consultoras jóvenes. Profesionales
                del sector, quemados.
              </p>
            </div>
            <div class="border-l border-neon pl-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-neon">
                Para qué
              </p>
              <p class="mt-2 text-sm leading-relaxed text-bone-soft">
                Construir comunidad antes que audiencia. Criterio antes que
                crecimiento. Profundidad antes que alcance.
              </p>
            </div>
          </div>
        </div>

        <!-- CTA secundario -->
        <div
          class="fade-up mt-16 flex flex-col items-start gap-6 sm:flex-row sm:items-center"
          style="animation-delay: 0.5s;"
        >
          <a
            href="/blog"
            class="group inline-flex items-center gap-3 border border-neon bg-neon px-6 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.28em] text-ink transition-colors hover:bg-transparent hover:text-neon"
          >
            Entrar al archivo
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
          </a>
          <a
            href="/manifiesto"
            class="group inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.28em] text-mute transition-colors hover:text-bone"
          >
            Leer el manifiesto
            <span aria-hidden="true" class="opacity-60 transition-all group-hover:opacity-100">↗</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ÚLTIMAS PUBLICACIONES — 3 featured -->
    <section class="relative border-b border-line px-4 py-24 sm:px-6 md:py-32 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <div class="mb-16 grid gap-8 md:grid-cols-12 md:items-end md:gap-10">
          <div class="md:col-span-8">
            <p class="mb-4 font-mono text-[11px] uppercase tracking-[0.3em] text-neon">
              [ Últimas publicaciones ]
            </p>
            <h2 class="font-serif text-4xl font-bold leading-[1.02] text-bone sm:text-5xl md:text-6xl">
              Los textos que te incomodan,<br />
              <span class="italic text-mute">cuando los tengo listos.</span>
            </h2>
          </div>
          <p class="text-sm leading-relaxed text-mute md:col-span-4">
            Se publica cuando hay algo que decir. No cuando el calendario pide.
            Si preferís el ritmo de redes, este lugar no es para vos.
          </p>
        </div>

        <div class="space-y-16 md:space-y-20">
          {
            featured.map((post, i) => (
              <PostCard
                slug={post.id}
                title={post.data.title}
                description={post.data.description}
                kicker={post.data.kicker}
                category={post.data.category}
                pubDate={post.data.pubDate}
                readingMinutes={post.data.readingMinutes}
                variant="feature"
                index={i}
              />
            ))
          }
        </div>

        <div class="mt-20 flex justify-center">
          <a
            href="/blog"
            class="group inline-flex items-center gap-3 border border-line bg-surface px-6 py-3 font-mono text-[11px] uppercase tracking-[0.28em] text-bone transition-colors hover:border-neon/60 hover:text-neon"
          >
            Ver archivo completo
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- DE QUÉ TRATA ESTO -->
    <section class="relative px-4 py-24 sm:px-6 md:py-32 lg:px-8">
      <div class="mx-auto grid max-w-6xl gap-14 md:grid-cols-12 md:gap-20">
        <div class="md:col-span-5">
          <p class="mb-6 font-mono text-[11px] uppercase tracking-[0.3em] text-mute">
            [ De qué trata esto ]
          </p>
          <h2 class="font-serif text-4xl font-bold leading-[1.05] text-bone sm:text-5xl">
            Una plataforma,<br />
            <span class="italic text-neon">tres canales.</span>
          </h2>
          <p class="mt-6 max-w-sm text-sm leading-relaxed text-mute">
            Arranca en texto — porque escribir obliga a pensar. Crece en video
            y podcast. Pero la base siempre va a ser esto.
          </p>
        </div>

        <div class="space-y-10 md:col-span-7">
          <div class="group flex gap-6 border-l border-neon pl-6 transition-colors">
            <span class="font-mono text-sm text-neon">01</span>
            <div>
              <h3 class="font-serif text-2xl font-bold text-bone">Blog</h3>
              <p class="mt-2 text-sm leading-relaxed text-bone-soft">
                El núcleo. Textos largos, sin resumen ejecutivo, sin thumbnails
                optimizados. Para leer despacio en una pausa real, no entre un
                mensaje de WhatsApp y otro.
              </p>
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.25em] text-neon">
                Disponible ahora
              </p>
            </div>
          </div>

          <div class="group flex gap-6 border-l border-line pl-6 transition-colors">
            <span class="font-mono text-sm text-mute">02</span>
            <div>
              <h3 class="font-serif text-2xl font-bold text-bone/80">YouTube</h3>
              <p class="mt-2 text-sm leading-relaxed text-mute">
                Ensayos en video. Formato largo. Sin cortes cada ocho segundos.
                Sin edición de TikTok aplicada a contenido que necesita
                respirar.
              </p>
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.25em] text-mute-dim">
                En preparación
              </p>
            </div>
          </div>

          <div class="group flex gap-6 border-l border-line pl-6 transition-colors">
            <span class="font-mono text-sm text-mute">03</span>
            <div>
              <h3 class="font-serif text-2xl font-bold text-bone/80">Podcast</h3>
              <p class="mt-2 text-sm leading-relaxed text-mute">
                Conversaciones con gente real del sector. No gurúes, no
                "expertos" con 300k followers y cero clientes. Profesionales
                que saben porque hicieron.
              </p>
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.25em] text-mute-dim">
                En preparación
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CIERRE MANIFESTO -->
    <section class="relative border-t border-line bg-surface/50 px-4 py-24 sm:px-6 md:py-32 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <p class="mb-6 font-mono text-[10px] uppercase tracking-[0.35em] text-neon">
          · · ·
        </p>
        <p class="font-serif text-3xl leading-[1.2] text-bone md:text-5xl">
          <span class="italic">"Construir marca no es aprender una herramienta —</span><br />
          es aprender a elegir qué <span class="text-neon not-italic">no</span> hacés."
        </p>
        <p class="mt-10 font-mono text-[11px] uppercase tracking-[0.3em] text-mute">
          Dominique Alexia
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
